# .env.example
#
# Copy to .env.local and fill in values.
# Lines marked REQUIRED will cause startup errors or locked endpoints if missing.

# ============================================================
# Supabase (REQUIRED)
# App will not start without these.
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# Twilio SMS (REQUIRED for notifications)
# Lead alerts, assignment notifications, and follow-up reminders
# will fail silently without these.
# ============================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional but recommended for post-job review automation.
GOOGLE_REVIEW_URL=

# SECURITY: In production, inbound webhook signature is required unless explicitly overridden.
# Keep this false in production unless you are debugging webhook proxy behavior.
TWILIO_ALLOW_UNSIGNED_WEBHOOK=false

# Primary admin phone for lead alerts (recommended)
ADMIN_ALERT_PHONE=

# ============================================================
# Cron / Internal Route Protection (REQUIRED)
#
# WARNING: If this is not set, /api/lead-followup and
# /api/notification-dispatch will reject ALL requests.
# Generate a strong random secret (e.g. openssl rand -hex 32).
# ============================================================
CRON_SECRET=

# ============================================================
# Resend Email (REQUIRED for quote and notification emails)
# ============================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ============================================================
# QuickBooks Online (OPTIONAL — simulated until configured)
# ============================================================
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=
QUICKBOOKS_ENCRYPTION_KEY=
QUICKBOOKS_ENVIRONMENT=sandbox
QUICKBOOKS_REALM_ID=

# ============================================================
# Upstash Redis (Rate Limiting)
# Required for distributed rate limiting in production.
# If unset, rate limiting degrades to allow-all with a warning.
# ============================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================================
# AI Assistant (OPTIONAL — falls back to rule-based responses)
# ============================================================
ANTHROPIC_API_KEY=

# ============================================================
# App
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature Gates
NEXT_PUBLIC_EMPLOYEE_INVENTORY=false

# ============================================================
# Development Only
#
# WARNING: Must NEVER be "true" in production.
# Bypasses ALL auth guards for /admin and /employee routes.
# The env validation will log a CRITICAL warning if this is
# "true" when NODE_ENV=production.
# ============================================================
NEXT_PUBLIC_DEV_PREVIEW_MODE=false
