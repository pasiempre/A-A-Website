/* ── Animated counter ── */
function AnimatedNumber({ target, suffix = "", isVisible }: { target: number; suffix?: string; isVisible: boolean }) {
  const [value, setValue] = useState(0);

  useEffect(() => {
    if (!isVisible) return;
    let start = 0;
    const duration = 1800;
    const increment = target / (duration / 16);
    const timer = setInterval(() => {
      start += increment;
      if (start >= target) {
        setValue(target);
        clearInterval(timer);
      } else {
        setValue(Math.floor(start));
      }
    }, 16);
    return () => clearInterval(timer);
  }, [isVisible, target]);

  return (
    <span className="font-serif text-4xl tracking-tight text-[#0A1628] md:text-5xl">
      {value}
      {suffix}
    </span>
  );
}

