          ref={trackRef}
          className={`relative mx-auto aspect-video max-w-5xl overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-lg transition duration-700 ${
            isVisible ? "translate-y-0 opacity-100" : "translate-y-8 opacity-0"
          }`}
          style={{ touchAction: "pan-y" }}
        >
          {/* After image (full) */}
          <Image
            src={item.after}
            alt="After cleaning"
            fill
            quality={72}
            sizes="(max-width: 1024px) 100vw, 960px"
            className="object-cover"
          />

          {/* Before image (clipped) */}
          <div
            className="absolute inset-y-0 left-0 overflow-hidden"
            style={{ width: `${position}%` }}
          >
            <Image
              src={item.before}
              alt="Before cleaning"
              fill
              quality={72}
              sizes="(max-width: 1024px) 100vw, 960px"
              className="object-cover grayscale-[30%]"
            />
          </div>

          {/* Bottom gradient for contrast */}
          <div className="pointer-events-none absolute inset-x-0 bottom-0 h-28 bg-gradient-to-t from-[#081120]/50 to-transparent" />

          {/* Slider handle */}
          <div
            className="absolute inset-y-0 z-10 w-0.5 -translate-x-1/2 cursor-ew-resize bg-white/90"
            style={{ left: `${position}%` }}
            role="slider"
            tabIndex={0}
            aria-label="Before and after comparison slider"
            aria-valuemin={0}
